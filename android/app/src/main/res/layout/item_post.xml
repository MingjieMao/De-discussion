<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/postRowRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_card"
    android:foreground="?attr/selectableItemBackground"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/textPostTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textAppearance="?attr/textAppearanceTitleMedium"
        android:textColor="@color/ink_primary"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/textPostAuthor"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textAppearance="?attr/textAppearanceBodyMedium"
        android:textColor="@color/ink_secondary" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/buttonPostLike"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="horizontal"
            android:minWidth="56dp"
            android:paddingEnd="18dp">

            <ImageView
                android:id="@+id/iconPostLike"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@string/action_like" />

            <TextView
                android:id="@+id/textPostLikeCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="@color/ink_secondary" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/textPostCount"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:minWidth="56dp"
            android:paddingEnd="18dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@string/reply_count_desc"
                android:src="@drawable/ic_reply_count_24" />

            <TextView
                android:id="@+id/textPostReplyCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="@color/ink_secondary" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
